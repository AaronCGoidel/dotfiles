[user]
	name = {{ .name | quote }}
	email = {{ .email | quote }}

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[pull]
	rebase = true

[fetch]
	prune = true

[core]
	pager = delta
	editor = nvim

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Catppuccin Mocha

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[alias]
	co = checkout
	br = branch
	st = status -sb
	lg = log --oneline --graph --decorate --all -20
	amend = commit --amend --no-edit
	unstage = reset HEAD --
	last = log -1 HEAD
