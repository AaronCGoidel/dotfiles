{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

# Install Homebrew if missing
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

echo "Installing formulae from Brewfile..."
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile" --no-upgrade --verbose || true

echo "Bootstrap complete. If any casks failed, install them manually with: brew install --cask <name>"
{{ end -}}
